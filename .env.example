# ERP Thaki - Backend Configuration

# === General ===
APP_NAME="ERP الذكي"
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string-min-32-chars
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# === ERPNext / Frappe ===
ERPNEXT_BASE_URL=https://your-erpnext-instance.com
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=

# === Odoo (later) ===
ODOO_URL=
ODOO_DB=
ODOO_USERNAME=
ODOO_PASSWORD=

# === AI providers ===
# Free tier recommended: gemini (Google AI Studio gives 1M tokens/day free).
# Get a key: https://aistudio.google.com/apikey
DEFAULT_AI_PROVIDER=gemini

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

GEMINI_API_KEY=
# 2.0-flash has 1,500 requests/day free (vs 20 for 2.5-flash). Use 2.5 only
# after enabling billing in Google AI Studio. Quality difference is small.
GEMINI_MODEL=gemini-2.0-flash

# Groq — used for Arabic speech-to-text via Whisper.
# Free tier: 7,200 transcriptions/day, no credit card.
# Get key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_WHISPER_MODEL=whisper-large-v3
# Cheap fast model for query classification — saves $ vs sending every
# message to Claude. Llama 3.3 70B handles classification well in Arabic.
GROQ_CLASSIFIER_MODEL=llama-3.3-70b-versatile

# === JWT ===
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# === Redis ===
REDIS_URL=redis://localhost:6379/0
